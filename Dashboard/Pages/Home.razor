@page "/"
@inject IServiceProvider mServiceProvider
@inject ILocalStorageService mLocalStorageService
@using Supabase;

<PageTitle>Home</PageTitle>

<h1>Hello, world!</h1>

Welcome to your new app.

@foreach(var idea in Ideas)
{
    <div>@idea.CreatedAt.ToString("g") : @idea.Text</div>
}

<button @onclick="AddIdea">Add a new idea</button>

@code {

    private Client _supabase = new("", null);

    private List<Idea> Ideas { get; set; } = [];

    public async Task AddIdea()
    {
        var idea = new Idea
        {
            Text = "New idea",
        };


        var result = await _supabase.From<Idea>().Insert(idea);
        
        if(result.Model is not null)
            Ideas.Add(result.Model);
    }

    public async Task GetIdeas()
    {
        // show current time
        // add the list of articles i find interesting in here
        // add the weather into here
        // add list of ideas related to work in a list having the status: new, active, completed and cancelled.


        // A result can be fetched like so.
        var result = await _supabase.From<Idea>().Get();
        Ideas.AddRange(result.Models);

    }

    protected override async Task OnInitializedAsync()
    {
        var appSettings = mLocalStorageService.GetAppSettings();
        var options = new SupabaseOptions
        {
            AutoConnectRealtime = false
        };

        _supabase = new Client(appSettings.SupabaseUrl, appSettings.SupabaseKey, options);

        await _supabase.InitializeAsync();


        await GetIdeas();
        await base.OnInitializedAsync();
    }
}
