@inherits LayoutComponentBase


<div class="page">
    <div class="sidebar">
        <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
            Home
        </NavLink>
        <NavLink class="nav-link" href="settings">
            Settings
        </NavLink>
    </div>

    <main>
        <ErrorBoundary>
            <ChildContent>
                @Body
            </ChildContent>
            <ErrorContent>
                <div>An exception has been thrown</div>
                <div>exception message:</div>
                <div>@context.Message</div>
                <div>stack trace:</div>
                <div>@context.StackTrace</div>
            </ErrorContent>
        </ErrorBoundary>
    </main>
</div>
