@inherits LayoutComponentBase
<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
        </div>

        <article class="content px-4">
            <ErrorBoundary>
                <ChildContent>
                    @Body
                </ChildContent> 
                <ErrorContent>
                    <div>An exception has been thrown</div>
                    <div>exception message:</div>
                    <div>@context.Message</div>
                    <div>stack trace:</div>
                    <div>@context.StackTrace</div>
                </ErrorContent>
            </ErrorBoundary>
        </article>
    </main>
</div>
